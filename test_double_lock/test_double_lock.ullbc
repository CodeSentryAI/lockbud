tex/futex.rs"},"crate_name":"std","contents":null},{"name":{"Local":"/rustc/library/std/src/sync/poison.rs"},"crate_name":"std","contents":null},{"name":{"Local":"/rustc/library/core/src/sync/atomic.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/core/src/cell.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/core/src/result.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/core/src/ptr/mod.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/core/src/fmt/rt.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/core/src/ptr/non_null.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/core/src/fmt/mod.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/std/src/io/stdio.rs"},"crate_name":"std","contents":null},{"name":{"Local":"/rustc/library/core/src/str/mod.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/std/src/panicking.rs"},"crate_name":"std","contents":null},{"name":{"Local":"/rustc/library/core/src/fmt/num.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/core/src/intrinsics/mod.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/core/src/panicking.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/core/src/panic/location.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/core/src/panic/panic_info.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/core/src/marker.rs"},"crate_name":"core","contents":null},{"name":{"Local":"/rustc/library/core/src/fmt/builders.rs"},"crate_name":"core","contents":null}],"type_decls":[{"def_id":0,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["sync",0]},{"Ident":["Mutex",0]},{"Instantiated":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"regions":[],"types":[{"Deduplicated":6}],"const_generics":[],"trait_refs":[]},"kind":"Other"}}],"span":{"data":{"file_id":2,"beg":{"line":227,"col":1},"end":{"line":227,"col":28}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" A mutual exclusion primitive useful for protecting shared data"},{"DocComment":""},{"DocComment":" This mutex will block threads waiting for the lock to become available. The"},{"DocComment":" mutex can be created via a [`new`] constructor. Each mutex has a type parameter"},{"DocComment":" which represents the data that it is protecting. The data can only be accessed"},{"DocComment":" through the RAII guards returned from [`lock`] and [`try_lock`], which"},{"DocComment":" guarantees that the data is only ever accessed when the mutex is locked."},{"DocComment":""},{"DocComment":" # Poisoning"},{"DocComment":""},{"DocComment":" The mutexes in this module implement a strategy called \"poisoning\" where a"},{"DocComment":" mutex becomes poisoned if it recognizes that the thread holding it has"},{"DocComment":" panicked."},{"DocComment":""},{"DocComment":" Once a mutex is poisoned, all other threads are unable to access the data by"},{"DocComment":" default as it is likely tainted (some invariant is not being upheld). For a"},{"DocComment":" mutex, this means that the [`lock`] and [`try_lock`] methods return a"},{"DocComment":" [`Result`] which indicates whether a mutex has been poisoned or not. Most"},{"DocComment":" usage of a mutex will simply [`unwrap()`] these results, propagating panics"},{"DocComment":" among threads to ensure that a possibly invalid invariant is not witnessed."},{"DocComment":""},{"DocComment":" Poisoning is only advisory: the [`PoisonError`] type has an [`into_inner`]"},{"DocComment":" method which will return the guard that would have otherwise been returned"},{"DocComment":" on a successful lock. This allows access to the data, despite the lock being"},{"DocComment":" poisoned."},{"DocComment":""},{"DocComment":" In addition, the panic detection is not ideal, so even unpoisoned mutexes"},{"DocComment":" need to be handled with care, since certain panics may have been skipped."},{"DocComment":" Here is a non-exhaustive list of situations where this might occur:"},{"DocComment":""},{"DocComment":" - If a mutex is locked while a panic is underway, e.g. within a [`Drop`]"},{"DocComment":"   implementation or a [panic hook], panicking for the second time while the"},{"DocComment":"   lock is held will leave the mutex unpoisoned. Note that while double panic"},{"DocComment":"   usually aborts the program, [`catch_unwind`] can prevent this."},{"DocComment":""},{"DocComment":" - Locking and unlocking the mutex across different panic contexts, e.g. by"},{"DocComment":"   storing the guard to a [`Cell`] within [`Drop::drop`] and accessing it"},{"DocComment":"   outside, or vice versa, can affect poisoning status in an unexpected way."},{"DocComment":""},{"DocComment":" - Foreign exceptions do not currently trigger poisoning even in absence of"},{"DocComment":"   other panics."},{"DocComment":""},{"DocComment":" While this rarely happens in realistic code, `unsafe` code cannot rely on"},{"DocComment":" poisoning for soundness, since the behavior of poisoning can depend on"},{"DocComment":" outside context. Here's an example of **incorrect** use of poisoning:"},{"DocComment":""},{"DocComment":" ```rust"},{"DocComment":" use std::sync::Mutex;"},{"DocComment":""},{"DocComment":" struct MutexBox<T> {"},{"DocComment":"     data: Mutex<*mut T>,"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" impl<T> MutexBox<T> {"},{"DocComment":"     pub fn new(value: T) -> Self {"},{"DocComment":"         Self {"},{"DocComment":"             data: Mutex::new(Box::into_raw(Box::new(value))),"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":""},{"DocComment":"     pub fn replace_with(&self, f: impl FnOnce(T) -> T) {"},{"DocComment":"         let ptr = self.data.lock().expect(\"poisoned\");"},{"DocComment":"         // While `f` is running, the data is moved out of `*ptr`. If `f`"},{"DocComment":"         // panics, `*ptr` keeps pointing at a dropped value. The intention"},{"DocComment":"         // is that this will poison the mutex, so the following calls to"},{"DocComment":"         // `replace_with` will panic without reading `*ptr`. But since"},{"DocComment":"         // poisoning is not guaranteed to occur if this is run from a panic"},{"DocComment":"         // hook, this can lead to use-after-free."},{"DocComment":"         unsafe {"},{"DocComment":"             (*ptr).write(f((*ptr).read()));"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [`new`]: Self::new"},{"DocComment":" [`lock`]: Self::lock"},{"DocComment":" [`try_lock`]: Self::try_lock"},{"DocComment":" [`unwrap()`]: Result::unwrap"},{"DocComment":" [`PoisonError`]: super::PoisonError"},{"DocComment":" [`into_inner`]: super::PoisonError::into_inner"},{"DocComment":" [panic hook]: crate::panic::set_hook"},{"DocComment":" [`catch_unwind`]: crate::panic::catch_unwind"},{"DocComment":" [`Cell`]: crate::cell::Cell"},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::sync::{Arc, Mutex};"},{"DocComment":" use std::thread;"},{"DocComment":" use std::sync::mpsc::channel;"},{"DocComment":""},{"DocComment":" const N: usize = 10;"},{"DocComment":""},{"DocComment":" // Spawn a few threads to increment a shared variable (non-atomically), and"},{"DocComment":" // let the main thread know once all increments are done."},{"DocComment":" //"},{"DocComment":" // Here we're using an Arc to share memory among threads, and the data inside"},{"DocComment":" // the Arc is protected with a mutex."},{"DocComment":" let data = Arc::new(Mutex::new(0));"},{"DocComment":""},{"DocComment":" let (tx, rx) = channel();"},{"DocComment":" for _ in 0..N {"},{"DocComment":"     let (data, tx) = (Arc::clone(&data), tx.clone());"},{"DocComment":"     thread::spawn(move || {"},{"DocComment":"         // The shared state can only be accessed once the lock is held."},{"DocComment":"         // Our non-atomic increment is safe because we're the only thread"},{"DocComment":"         // which can access the shared state when the lock is held."},{"DocComment":"         //"},{"DocComment":"         // We unwrap() the return value to assert that we are not expecting"},{"DocComment":"         // threads to ever fail while holding the lock."},{"DocComment":"         let mut data = data.lock().unwrap();"},{"DocComment":"         *data += 1;"},{"DocComment":"         if *data == N {"},{"DocComment":"             tx.send(()).unwrap();"},{"DocComment":"         }"},{"DocComment":"         // the lock is unlocked here when `data` goes out of scope."},{"DocComment":"     });"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" rx.recv().unwrap();"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" To recover from a poisoned mutex:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::sync::{Arc, Mutex};"},{"DocComment":" use std::thread;"},{"DocComment":""},{"DocComment":" let lock = Arc::new(Mutex::new(0_u32));"},{"DocComment":" let lock2 = Arc::clone(&lock);"},{"DocComment":""},{"DocComment":" let _ = thread::spawn(move || -> () {"},{"DocComment":"     // This thread will acquire the mutex first, unwrapping the result of"},{"DocComment":"     // `lock` because the lock has not been poisoned."},{"DocComment":"     let _guard = lock2.lock().unwrap();"},{"DocComment":""},{"DocComment":"     // This panic while holding the lock (`_guard` is in scope) will poison"},{"DocComment":"     // the mutex."},{"DocComment":"     panic!();"},{"DocComment":" }).join();"},{"DocComment":""},{"DocComment":" // The lock is poisoned by this point, but the returned result can be"},{"DocComment":" // pattern matched on to return the underlying guard on both branches."},{"DocComment":" let mut guard = match lock.lock() {"},{"DocComment":"     Ok(guard) => guard,"},{"DocComment":"     Err(poisoned) => poisoned.into_inner(),"},{"DocComment":" };"},{"DocComment":""},{"DocComment":" *guard += 1;"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" To unlock a mutex guard sooner than the end of the enclosing scope,"},{"DocComment":" either create an inner scope or drop the guard manually."},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::sync::{Arc, Mutex};"},{"DocComment":" use std::thread;"},{"DocComment":""},{"DocComment":" const N: usize = 3;"},{"DocComment":""},{"DocComment":" let data_mutex = Arc::new(Mutex::new(vec![1, 2, 3, 4]));"},{"DocComment":" let res_mutex = Arc::new(Mutex::new(0));"},{"DocComment":""},{"DocComment":" let mut threads = Vec::with_capacity(N);"},{"DocComment":" (0..N).for_each(|_| {"},{"DocComment":"     let data_mutex_clone = Arc::clone(&data_mutex);"},{"DocComment":"     let res_mutex_clone = Arc::clone(&res_mutex);"},{"DocComment":""},{"DocComment":"     threads.push(thread::spawn(move || {"},{"DocComment":"         // Here we use a block to limit the lifetime of the lock guard."},{"DocComment":"         let result = {"},{"DocComment":"             let mut data = data_mutex_clone.lock().unwrap();"},{"DocComment":"             // This is the result of some important and long-ish work."},{"DocComment":"             let result = data.iter().fold(0, |acc, x| acc + x * 2);"},{"DocComment":"             data.push(result);"},{"DocComment":"             result"},{"DocComment":"             // The mutex guard gets dropped here, together with any other values"},{"DocComment":"             // created in the critical section."},{"DocComment":"         };"},{"DocComment":"         // The guard created here is a temporary dropped at the end of the statement, i.e."},{"DocComment":"         // the lock would not remain being held even if the thread did some additional work."},{"DocComment":"         *res_mutex_clone.lock().unwrap() += result;"},{"DocComment":"     }));"},{"DocComment":" });"},{"DocComment":""},{"DocComment":" let mut data = data_mutex.lock().unwrap();"},{"DocComment":" // This is the result of some important and long-ish work."},{"DocComment":" let result = data.iter().fold(0, |acc, x| acc + x * 2);"},{"DocComment":" data.push(result);"},{"DocComment":" // We drop the `data` explicitly because it's not necessary anymore and the"},{"DocComment":" // thread still has work to do. This allows other threads to start working on"},{"DocComment":" // the data immediately, without waiting for the rest of the unrelated work"},{"DocComment":" // to be done here."},{"DocComment":" //"},{"DocComment":" // It's even more important here than in the threads because we `.join` the"},{"DocComment":" // threads after that. If we had not dropped the mutex guard, a thread could"},{"DocComment":" // be waiting forever for it, causing a deadlock."},{"DocComment":" // As in the threads, a block could have been used instead of calling the"},{"DocComment":" // `drop` function."},{"DocComment":" drop(data);"},{"DocComment":" // Here the mutex guard is not assigned to a variable and so, even if the"},{"DocComment":" // scope does not end after this line, the mutex is still released: there is"},{"DocComment":" // no deadlock."},{"DocComment":" *res_mutex.lock().unwrap() += result;"},{"DocComment":""},{"DocComment":" threads.into_iter().for_each(|thread| {"},{"DocComment":"     thread"},{"DocComment":"         .join()"},{"DocComment":"         .expect(\"The thread creating or execution failed !\")"},{"DocComment":" });"},{"DocComment":""},{"DocComment":" assert_eq!(*res_mutex.lock().unwrap(), 800);"},{"DocComment":" ```"},{"DocComment":""},{"Unknown":{"path":"rustc_diagnostic_item","args":"Mutex"}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":n