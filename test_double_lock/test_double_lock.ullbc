al":false,"opacity":"Transparent","lang_item":null},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[{"Deduplicated":47},{"Deduplicated":43}],"output":{"Deduplicated":40}},"src":"TopLevel","is_global_initializer":null,"body":"Missing"},{"def_id":16,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["ptr",0]},{"Ident":["drop_in_place",0]},{"Instantiated":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"regions":[],"types":[{"Deduplicated":39}],"const_generics":[],"trait_refs":[]},"kind":"Other"}}],"span":{"data":{"file_id":8,"beg":{"line":805,"col":1},"end":{"line":807,"col":25}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Executes the destructor (if any) of the pointed-to value."},{"DocComment":""},{"DocComment":" This is almost the same as calling [`ptr::read`] and discarding"},{"DocComment":" the result, but has the following advantages:"},{"DocComment":""},{"DocComment":" * It is *required* to use `drop_in_place` to drop unsized types like"},{"DocComment":"   trait objects, because they can't be read out onto the stack and"},{"DocComment":"   dropped normally."},{"DocComment":""},{"DocComment":" * It is friendlier to the optimizer to do this over [`ptr::read`] when"},{"DocComment":"   dropping manually allocated memory (e.g., in the implementations of"},{"DocComment":"   `Box`/`Rc`/`Vec`), as the compiler doesn't need to prove that it's"},{"DocComment":"   sound to elide the copy."},{"DocComment":""},{"DocComment":" * It can be used to drop [pinned] data when `T` is not `repr(packed)`"},{"DocComment":"   (pinned data must not be moved before it is dropped)."},{"DocComment":""},{"DocComment":" Unaligned values cannot be dropped in place, they must be copied to an aligned"},{"DocComment":" location first using [`ptr::read_unaligned`]. For packed structs, this move is"},{"DocComment":" done automatically by the compiler. This means the fields of packed structs"},{"DocComment":" are not dropped in-place."},{"DocComment":""},{"DocComment":" [`ptr::read`]: self::read"},{"DocComment":" [`ptr::read_unaligned`]: self::read_unaligned"},{"DocComment":" [pinned]: crate::pin"},{"DocComment":""},{"DocComment":" # Safety"},{"DocComment":""},{"DocComment":" Behavior is undefined if any of the following conditions are violated:"},{"DocComment":""},{"DocComment":" * `to_drop` must be [valid] for both reads and writes."},{"DocComment":""},{"DocComment":" * `to_drop` must be properly aligned, even if `T` has size 0."},{"DocComment":""},{"DocComment":" * `to_drop` must be nonnull, even if `T` has size 0."},{"DocComment":""},{"DocComment":" * The value `to_drop` points to must be valid for dropping, which may mean"},{"DocComment":"   it must uphold additional invariants. These invariants depend on the type"},{"DocComment":"   of the value being dropped. For instance, when dropping a Box, the box's"},{"DocComment":"   pointer to the heap must be valid."},{"DocComment":""},{"DocComment":" * While `drop_in_place` is executing, the only way to access parts of"},{"DocComment":"   `to_drop` is through the `&mut self` references supplied to the"},{"DocComment":"   `Drop::drop` methods that `drop_in_place` invokes."},{"DocComment":""},{"DocComment":" Additionally, if `T` is not [`Copy`], using the pointed-to value after"},{"DocComment":" calling `drop_in_place` can cause undefined behavior. Note that `*to_drop ="},{"DocComment":" foo` counts as a use because it will cause the value to be dropped"},{"DocComment":" again. [`write()`] can be used to overwrite data without causing it to be"},{"DocComment":" dropped."},{"DocComment":""},{"DocComment":" [valid]: self#safety"},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" Manually remove the last item from a vector:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ptr;"},{"DocComment":" use std::rc::Rc;"},{"DocComment":""},{"DocComment":" let last = Rc::new(1);"},{"DocComment":" let weak = Rc::downgrade(&last);"},{"DocComment":""},{"DocComment":" let mut v = vec![Rc::new(0), last];"},{"DocComment":""},{"DocComment":" unsafe {"},{"DocComment":"     // Get a raw pointer to the last element in `v`."},{"DocComment":"     let ptr = &mut v[1] as *mut _;"},{"DocComment":"     // Shorten `v` to prevent the last item from being dropped. We do that first,"},{"DocComment":"     // to prevent issues if the `drop_in_place` below panics."},{"DocComment":"     v.set_len(1);"},{"DocComment":"     // Without a call `drop_in_place`, the last item would never be dropped,"},{"DocComment":"     // and the memory it manages would be leaked."},{"DocComment":"     ptr::drop_in_place(ptr);"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" assert_eq!(v, &[0.into()]);"},{"DocComment":""},{"DocComment":" // Ensure that the last item was dropped."},{"DocComment":" assert!(weak.upgrade().is_none());"},{"DocComment":" ```"},{"Unknown":{"path":"rustc_diagnostic_item","args":"ptr_drop_in_place"}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":"drop_in_place"},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[{"Deduplicated":48}],"output":{"Deduplicated":0}},"src":"TopLevel","is_global_initializer":null,"body":{"Unstructured":{"span":{"data":{"file_id":8,"beg":{"line":805,"col":1},"end":{"line":807,"col":25}},"generated_from_span":null},"bound_body_regions":0,"locals":{"arg_count":1,"locals":[{"index":0,"name":null,"span":{"data":{"file_id":8,"beg":{"line":805,"col":1},"end":{"line":807,"col":25}},"generated_from_span":null},"ty":{"Deduplicated":0}},{"index":1,"name":null,"span"