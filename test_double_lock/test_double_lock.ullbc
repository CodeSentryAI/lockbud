ot `Path`, which could be unexpected."},{"DocComment":" See [`Location::file`]'s documentation for more discussion."}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":"panic_location"},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[{"span":{"data":{"file_id":18,"beg":{"line":39,"col":1},"end":{"line":39,"col":24}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"filename","ty":{"HashConsedValue":[102,{"Adt":{"id":{"Adt":35},"generics":{"regions":[],"types":[],"const_generics":[],"trait_refs":[]}}}]}},{"span":{"data":{"file_id":18,"beg":{"line":39,"col":1},"end":{"line":39,"col":24}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"line","ty":{"Deduplicated":24}},{"span":{"data":{"file_id":18,"beg":{"line":39,"col":1},"end":{"line":39,"col":24}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"col","ty":{"Deduplicated":24}},{"span":{"data":{"file_id":18,"beg":{"line":39,"col":1},"end":{"line":39,"col":24}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"_filename","ty":{"HashConsedValue":[103,{"Adt":{"id":{"Adt":36},"generics":{"regions":[],"types":[],"const_generics":[],"trait_refs":[]}}}]}}]},"layout":{"size":24,"align":8,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[0,16,20,24],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":33,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["fmt",0]},{"Ident":["Error",0]}],"span":{"data":{"file_id":11,"beg":{"line":109,"col":1},"end":{"line":109,"col":17}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" The error type which is returned from formatting a message into a stream."},{"DocComment":""},{"DocComment":" This type does not support transmission of an error other than that an error"},{"DocComment":" occurred. This is because, despite the existence of this error,"},{"DocComment":" string formatting is considered an infallible operation."},{"DocComment":" `fmt()` implementors should not return this `Error` unless they received it from their"},{"DocComment":" [`Formatter`]. The only time your code should create a new instance of this"},{"DocComment":" error is when implementing `fmt::Write`, in order to cancel the formatting operation when"},{"DocComment":" writing to the underlying stream fails."},{"DocComment":""},{"DocComment":" Any extra information must be arranged to be transmitted through some other means,"},{"DocComment":" such as storing it in a field to be consulted after the formatting operation has been"},{"DocComment":" cancelled. (For example, this is how [`std::io::Write::write_fmt()`] propagates IO errors"},{"DocComment":" during writing.)"},{"DocComment":""},{"DocComment":" This type, `fmt::Error`, should not be"},{"DocComment":" confused with [`std::io::Error`] or [`std::error::Error`], which you may also"},{"DocComment":" have in scope."},{"DocComment":""},{"DocComment":" [`std::io::Error`]: ../../std/io/struct.Error.html"},{"DocComment":" [`std::io::Write::write_fmt()`]: ../../std/io/trait.Write.html#method.write_fmt"},{"DocComment":" [`std::error::Error`]: ../../std/error/trait.Error.html"},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ```rust"},{"DocComment":" use std::fmt::{self, write};"},{"DocComment":""},{"DocComment":" let mut output = String::new();"},{"DocComment":" if let Err(fmt::Error) = write(&mut output, format_args!(\"Hello {}!\", \"world\")) {"},{"DocComment":"     panic!(\"An error occurred\");"},{"DocComment":" }"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":null},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[]},"layout":{"size":0,"align":1,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":34,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["fmt",0]},{"Ident":["FormattingOptions",0]}],"span":{"data":{"file_id":11,"beg":{"line":287,"col":1},"end":{"line":287,"col":29}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Options for formatting."},{"DocComment":""},{"DocComment":" `FormattingOptions` is a [`Formatter`] without an attached [`Write`] trait."},{"DocComment":" It is mainly used to construct `Formatter` instances."}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":null},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[{"span":{"data":{"file_id":11,"beg":{"line":287,"col":1},"end":{"line":287,"col":29}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"flags","ty":{"Deduplicated":24}},{"span":{"data":{"file_id":11,"beg":{"line":287,"col":1},"end":{"line":287,"col":29}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"width","ty":{"Deduplicated":98}},{"span":{"data":{"file_id":11,"beg":{"line":287,"col":1},"end":{"line":287,"col":29}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"precision","ty":{"Deduplicated":98}}]},"layout":{"size":8,"align":4,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[0,4,6],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":35,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["ptr",0]},{"Ident":["NonNull",0]},{"Instantiated":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"regions":[],"types":[{"Deduplicated":46}],"const_generics":[],"trait_refs":[]},"kind":"Other"}}],"span":{"data":{"file_id":10,"beg":{"line":76,"col":1},"end":{"line":76,"col":36}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" `*mut T` but non-zero and [covariant]."},{"DocComment":""},{"DocComment":" This is often the correct thing to use when building data structures using"},{"DocComment":" raw pointers, but is ultimately more dangerous to use because of its additional"},{"DocComment":" properties. If you're not sure if you should use `NonNull<T>`, just use `*mut T`!"},{"DocComment":""},{"DocComment":" Unlike `*mut T`, the pointer must always be non-null, even if the pointer"},{"DocComment":" is never dereferenced. This is so that enums may use this forbidden value"},{"DocComment":" as a discriminant -- `Option<NonNull<T>>` has the same size as `*mut T`."},{"DocComment":" However the pointer may still dangle if it isn't dereferenced."},{"DocComment":""},{"DocComment":" Unlike `*mut T`, `NonNull<T>` is covariant over `T`. This is usually the correct"},{"DocComment":" choice for most data structures and safe abstractions, such as `Box`, `Rc`, `Arc`, `Vec`,"},{"DocComment":" and `LinkedList`."},{"DocComment":""},{"DocComment":" In rare cases, if your type exposes a way to mutate the value of `T` through a `NonNull<T>`,"},{"DocComment":" and you need to prevent unsoundness from variance (for example, if `T` could be a reference"},{"DocComment":" with a shorter lifetime), you should add a field to make your type invariant, such as"},{"DocComment":" `PhantomData<Cell<T>>` or `PhantomData<&'a mut T>`."},{"DocComment":""},{"DocComment":" Example of a type that must be invariant:"},{"DocComment":" ```rust"},{"DocComment":" use std::cell::Cell;"},{"DocComment":" use std::marker::PhantomData;"},{"DocComment":" struct Invariant<T> {"},{"DocComment":"     ptr: std::ptr::NonNull<T>,"},{"DocComment":"     _invariant: PhantomData<Cell<T>>,"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Notice that `NonNull<T>` has a `From` instance for `&T`. However, this does"},{"DocComment":" not change the fact that mutating through a (pointer derived from a) shared"},{"DocComment":" reference is undefined behavior unless the mutation happens inside an"},{"DocComment":" [`UnsafeCell<T>`]. The same goes for creating a mutable reference from a shared"},{"DocComment":" reference. When using this `From` instance without an `UnsafeCell<T>`,"},{"DocComment":" it is your responsibility to ensure that `as_mut` is never called, and `as_ptr`"},{"DocComment":" is never used for mutation."},{"DocComment":""},{"DocComment":" # Representation"},{"DocComment":""},{"DocComment":" Thanks to the [null pointer optimization],"},{"DocComment":" `NonNull<T>` and `Option<NonNull<T>>`"},{"DocComment":" are guaranteed to have the same size and alignment:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ptr::NonNull;"},{"DocComment":""},{"DocComment":" assert_eq!(size_of::<NonNull<i16>>(), size_of::<Option<NonNull<i16>>>());"},{"DocComment":" assert_eq!(align_of::<NonNull<i16>>(), align_of::<Option<NonNull<i16>>>());"},{"DocComment":""},{"DocComment":" assert_eq!(size_of::<NonNull<str>>(), size_of::<Option<NonNull<str>>>());"},{"DocComment":" assert_eq!(align_of::<NonNull<str>>(), align_of::<Option<NonNull<str>>>());"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [covariant]: https://doc.rust-lang.org/reference/subtyping.html"},{"DocComment":" [`PhantomData`]: crate::marker::PhantomData"},{"DocComment":" [`UnsafeCell<T>`]: crate::cell::UnsafeCell"},{"DocComment":" [null pointer optimization]: crate::option#representation"},{"Unknown":{"path":"rustc_nonnull_optimization_guaranteed","args":null}},{"Unknown":{"path":"rustc_diagnostic_item","args":"NonNull"}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":null},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[{"span":{"data":{"file_id":10,"beg":{"line":76,"col":1},"end":{"line":76,"col":36}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"pointer","ty":{"HashConsedValue":[68,{"RawPtr":[{"Deduplicated":46},"Shared"]}]}}]},"layout":{"size":16,"align":8,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[0],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":36,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["marker",0]},{"Ident":["PhantomData",0]},{"Instantiated":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"regions":[],"types":[{"Deduplicated":47}],"const_generics":[],"trait_refs":[]},"kind":"Other"}}],"span":{"data":{"file_id":20,"beg":{"line":814,"col":1},"end":{"line":814,"col":40}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Zero-sized type used to mark things that \"act like\" they own a `T`."},{"DocComment":""},{"DocComment":" Adding a `PhantomData<T>` field to your type tells the compiler that your"},{"DocComment":" type acts as though it stores a value of type `T`, even though it doesn't"},{"DocComment":" really. This information is used when computing certain safety properties."},{"DocComment":""},{"DocComment":" For a more in-depth explanation of how to use `PhantomData<T>`, please see"},{"DocComment":" [the Nomicon](../../nomicon/phantom-data.html)."},{"DocComment":""},{"DocComment":" # A ghastly note 👻👻👻"},{"DocComment":""},{"DocComment":" Though they both have scary names, `PhantomData` and 'phantom types' are"},{"DocComment":" related, but not identical. A phantom type parameter is simply a type"},{"DocComment":" parameter which is never used. In Rust, this often causes the compiler to"},{"DocComment":" complain, and the solution is to add a \"dummy\" use by way of `PhantomData`."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ## Unused lifetime parameters"},{"DocComment":""},{"DocComment":" Perhaps the most common use case for `PhantomData` is a struct that has an"},{"DocComment":" unused lifetime parameter, typically as part of some unsafe code. For"},{"DocComment":" example, here is a struct `Slice` that has two pointers of type `*const T`,"},{"DocComment":" presumably pointing into an array somewhere:"},{"DocComment":""},{"DocComment":" ```compile_fail,E0392"},{"DocComment":" struct Slice<'a, T> {"},{"DocComment":"     start: *const T,"},{"DocComment":"     end: *const T,"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" The intention is that the underlying data is only valid for the"},{"DocComment":" lifetime `'a`, so `Slice` should not outlive `'a`. However, this"},{"DocComment":" intent is not expressed in the code, since there are no uses of"},{"DocComment":" the lifetime `'a` and hence it is not clear what data it applies"},{"DocComment":" to. We can correct this by telling the compiler to act *as if* the"},{"DocComment":" `Slice` struct contained a reference `&'a T`:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::marker::PhantomData;"},{"DocComment":""},{"DocComment":" # #[allow(dead_code)]"},{"DocComment":" struct Slice<'a, T> {"},{"DocComment":"     start: *const T,"},{"DocComment":"     end: *const T,"},{"DocComment":"     phantom: PhantomData<&'a T>,"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" This also in turn infers the lifetime bound `T: 'a`, indicating"},{"DocComment":" that any references in `T` are valid over the lifetime `'a`."},{"DocComment":""},{"DocComment":" When initializing a `Slice` you simply provide the value"},{"DocComment":" `PhantomData` for the field `phantom`:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" # #![allow(dead_code)]"},{"DocComment":" # use std::marker::PhantomData;"},{"DocComment":" # struct Slice<'a, T> {"},{"DocComment":" #     start: *const T,"},{"DocComment":" #     end: *const T,"},{"DocComment":" #     phantom: PhantomData<&'a T>,"},{"DocComment":" # }"},{"DocComment":" fn borrow_vec<T>(vec: &Vec<T>) -> Slice<'_, T> {"},{"DocComment":"     let ptr = vec.as_ptr();"},{"DocComment":"     Slice {"},{"DocComment":"         start: ptr,"},{"DocComment":"         end: unsafe { ptr.add(vec.len()) },"},{"DocComment":"         phantom: PhantomData,"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" ## Unused type parameters"},{"DocComment":""},{"DocComment":" It sometimes happens that you have unused type parameters which"},{"DocComment":" indicate what type of data a struct is \"tied\" to, even though that"},{"DocComment":" data is not actually found in the struct itself. Here is an"},{"DocComment":" example where this arises with [FFI]. The foreign interface uses"},{"DocComment":" handles of type `*mut ()` to refer to Rust values of different"},{"DocComment":" types. We track the Rust type using a phantom type parameter on"},{"DocComment":" the struct `ExternalResource` which wraps a handle."},{"DocComment":""},{"DocComment":" [FFI]: ../../book/ch19-01-unsafe-rust.html#using-extern-functions-to-call-external-code"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" # #![allow(dead_code)]"},{"DocComment":" # trait ResType { }"},{"DocComment":" # struct ParamType;"},{"DocComment":" # mod foreign_lib {"},{"DocComment":" #     pub fn new(_: usize) -> *mut () { 42 as *mut () }"},{"DocComment":" #     pub fn do_stuff(_: *mut (), _: usize) {}"},{"DocComment":" # }"},{"DocComment":" # fn convert_params(_: ParamType) -> usize { 42 }"},{"DocComment":" use std::marker::PhantomData;"},{"DocComment":""},{"DocComment":" struct ExternalResource<R> {"},{"DocComment":"    resource_handle: *mut (),"},{"DocComment":"    resource_type: PhantomData<R>,"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" impl<R: ResType> ExternalResource<R> {"},{"DocComment":"     fn new() -> Self {"},{"DocComment":"         let size_of_res = size_of::<R>();"},{"DocComment":"         Self {"},{"DocComment":"             resource_handle: foreign_lib::new(size_of_res),"},{"DocComment":"             resource_type: PhantomData,"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":""},{"DocComment":"     fn do_stuff(&self, param: ParamType) {"},{"DocComment":"         let foreign_params = convert_params(param);"},{"DocComment":"         foreign_lib::do_stuff(self.resource_handle, foreign_params);"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" ## Ownership and the drop check"},{"DocComment":""},{"DocComment":" The exact interaction of `PhantomData` with drop check **may change in the future**."},{"DocComment":""},{"DocComment":" Currently, adding a field of type `PhantomData<T>` indicates that your type *owns* data of type"},{"DocComment":" `T` in very rare circumstances. This in turn has effects on the Rust compiler's [drop check]"},{"DocComment":" analysis. For the exact rules, see the [drop check] documentation."},{"DocComment":""},{"DocComment":" ## Layout"},{"DocComment":""},{"DocComment":" For all `T`, the following are guaranteed:"},{"DocComment":" * `size_of::<PhantomData<T>>() == 0`"},{"DocComment":" * `align_of::<PhantomData<T>>() == 1`"},{"DocComment":""},{"DocComment":" [drop check]: Drop#drop-check"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":"phantom_data"},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[]},"layout":{"size":0,"align":1,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":37,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["fmt",0]},{"Ident":["DebugStruct",0]},{"Instantiated":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"regions":["Erased","Erased"],"types":[],"const_generics":[],"trait_refs":[]},"kind":"Other"}}],"span":{"data":{"file_id":21,"beg":{"line":88,"col":1},"end":{"line":88,"col":35}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" A struct to help with [`fmt::Debug`](Debug) implementations."},{"DocComment":""},{"DocComment":" This is useful when you wish to output a formatted struct as a part of your"},{"DocComment":" [`Debug::fmt`] implementation."},{"DocComment":""},{"DocComment":" This can be constructed by the [`Formatter::debug_struct`] method."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::fmt;"},{"DocComment":""},{"DocComment":" struct Foo {"},{"DocComment":"     bar: i32,"},{"DocComment":"     baz: String,"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" impl fmt::Debug for Foo {"},{"DocComment":"     fn fmt(&self, fmt: &mut fmt::Formatter<'_>) -> fmt::Result {"},{"DocComment":"         fmt.debug_struct(\"Foo\")"},{"DocComment":"            .field(\"bar\", &self.bar)"},{"DocComment":"            .field(\"baz\", &self.baz)"},{"DocComment":"            .finish()"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment