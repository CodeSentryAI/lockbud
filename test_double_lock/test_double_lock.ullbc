t":" documentation of the methods defined on `Formatter` below."},{"Unknown":{"path":"rustc_diagnostic_item","args":"Formatter"}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":null},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[{"span":{"data":{"file_id":11,"beg":{"line":561,"col":1},"end":{"line":561,"col":25}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"options","ty":{"Deduplicated":99}},{"span":{"data":{"file_id":11,"beg":{"line":561,"col":1},"end":{"line":561,"col":25}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"buf","ty":{"Deduplicated":100}}]},"layout":{"size":24,"align":8,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[16,0],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":22,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["marker",0]},{"Ident":["PhantomData",0]},{"Instantiated":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"regions":[],"types":[{"Deduplicated":101}],"const_generics":[],"trait_refs":[]},"kind":"Other"}}],"span":{"data":{"file_id":20,"beg":{"line":814,"col":1},"end":{"line":814,"col":40}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Zero-sized type used to mark things that \"act like\" they own a `T`."},{"DocComment":""},{"DocComment":" Adding a `PhantomData<T>` field to your type tells the compiler that your"},{"DocComment":" type acts as though it stores a value of type `T`, even though it doesn't"},{"DocComment":" really. This information is used when computing certain safety properties."},{"DocComment":""},{"DocComment":" For a more in-depth explanation of how to use `PhantomData<T>`, please see"},{"DocComment":" [the Nomicon](../../nomicon/phantom-data.html)."},{"DocComment":""},{"DocComment":" # A ghastly note 👻👻👻"},{"DocComment":""},{"DocComment":" Though they both have scary names, `PhantomData` and 'phantom types' are"},{"DocComment":" related, but not identical. A phantom type parameter is simply a type"},{"DocComment":" parameter which is never used. In Rust, this often causes the compiler to"},{"DocComment":" complain, and the solution is to add a \"dummy\" use by way of `PhantomData`."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ## Unused lifetime parameters"},{"DocComment":""},{"DocComment":" Perhaps the most common use case for `PhantomData` is a struct that has an"},{"DocComment":" unused lifetime parameter, typically as part of some unsafe code. For"},{"DocComment":" example, here is a struct `Slice` that has two pointers of type `*const T`,"},{"DocComment":" presumably pointing into an array somewhere:"},{"DocComment":""},{"DocComment":" ```compile_fail,E0392"},{"DocComment":" struct Slice<'a, T> {"},{"DocComment":"     start: *const T,"},{"DocComment":"     end: *const T,"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" The intention is that the underlying data is only valid for the"},{"DocComment":" lifetime `'a`, so `Slice` should not outlive `'a`. However, this"},{"DocComment":" intent is not expressed in the code, since there are no uses of"},{"DocComment":" the lifetime `'a` and hence it is not clear what data it applies"},{"DocComment":" to. We can correct this by telling the compiler to act *as if* the"},{"DocComment":" `Slice` struct contained a reference `&'a T`:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::marker::PhantomData;"},{"DocComment":""},{"DocComment":" # #[allow(dead_code)]"},{"DocComment":" struct Slice<'a, T> {"},{"DocComment":"     start: *const T,"},{"DocComment":"     end: *const T,"},{"DocComment":"     phantom: PhantomData<&'a T>,"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" This also in turn infers the lifetime bound `T: 'a`, indicating"},{"DocComment":" that any references in `T` are valid over the lifetime `'a`."},{"DocComment":""},{"DocComment":" When initializing a `Slice` you simply provide the value"},{"DocComment":" `PhantomData` for the field `phantom`:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" # #![allow(dead_code)]"},{"DocComment":" # use std::marker::PhantomData;"},{"DocComment":" # struct Slice<'a, T> {"},{"DocComment":" #     start: *const T,"},{"DocComment":" #     end: *const T,"},{"DocComment":" #     phantom: PhantomData<&'a T>,"},{"DocComment":" # }"},{"DocComment":" fn borrow_vec<T>(vec: &Vec<T>) -> Slice<'_, T> {"},{"DocComment":"     let ptr = vec.as_ptr();"},{"DocComment":"     Slice {"},{"DocComment":"         start: ptr,"},{"DocComment":"         end: unsafe { ptr.add(vec.len()) },"},{"DocComment":"         phantom: PhantomData,"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" ## Unused type parameters"},{"DocComment":""},{"DocComment":" It sometimes happens that you have unused type parameters which"},{"DocComment":" indicate what type of data a struct is \"tied\" to, even though that"},{"DocComment":" data is not actually found in the struct itself. Here is an"},{"DocComment":" example where this arises with [FFI]. The foreign interface uses"},{"DocComment":" handles of type `*mut ()` to refer to Rust values of different"},{"DocComment":" types. We track the Rust type using a phantom type parameter on"},{"DocComment":" the struct `ExternalResource` which wraps a handle."},{"DocComment":""},{"DocComment":" [FFI]: ../../book/ch19-01-unsafe-rust.html#using-extern-functions-to-call-external-code"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" # #![allow(dead_code)]"},{"DocComment":" # trait ResType { }"},{"DocComment":" # struct ParamType;"},{"DocComment":" # mod foreign_lib {"},{"DocComment":" #     pub fn new(_: usize) -> *mut () { 42 as *mut () }"},{"DocComment":" #     pub fn do_stuff(_: *mut (), _: usize) {}"},{"DocComment":" # }"},{"DocComment":" # fn convert_params(_: ParamType) -> usize { 42 }"},{"DocComment":" use std::marker::PhantomData;"},{"DocComment":""},{"DocComment":" struct ExternalResource<R> {"},{"DocComment":"    resource_handle: *mut (),"},{"DocComment":"    resource_type: PhantomData<R>,"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" impl<R: ResType> ExternalResource<R> {"},{"DocComment":"     fn new() -> Self {"},{"DocComment":"         let size_of_res = size_of::<R>();"},{"DocComment":"         Self {"},{"DocComment":"             resource_handle: foreign_lib::new(size_of_res),"},{"DocComment":"             resource_type: PhantomData,"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":""},{"DocComment":"     fn do_stuff(&self, param: ParamType) {"},{"DocComment":"         let foreign_params = convert_params(param);"},{"DocComment":"         foreign_lib::do_stuff(self.resource_handle, foreign_params);"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" ## Ownership and the drop check"},{"DocComment":""},{"DocComment":" The exact interaction of `PhantomData` with drop check **may change in the future**."},{"DocComment":""},{"DocComment":" Currently, adding a field of type `PhantomData<T>` indicates that your type *owns* data of type"},{"DocComment":" `T` in very rare circumstances. This in turn has effects on the Rust compiler's [drop check]"},{"DocComment":" analysis. For the exact rules, see the [drop check] documentation."},{"DocComment":""},{"DocComment":" ## Layout"},{"DocComment":""},{"DocComment":" For all `T`, the following are guaranteed:"},{"DocComment":" * `size_of::<PhantomData<T>>() == 0`"},{"DocComment":" * `align_of::<PhantomData<T>>() == 1`"},{"DocComment":""},{"DocComment":" [drop check]: Drop#drop-check"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":"phantom_data"},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[]},"layout":{"size":0,"align":1,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":23,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["ptr",0]},{"Ident":["NonNull",0]},{"Instantiated":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"regions":[],"types":[{"Deduplicated":13}],"const_generics":[],"trait_refs":[]},"kind":"Other"}}],"span":{"data":{"file_id":10,"beg":{"line":76,"col":1},"end":{"line":76,"col":36}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" `*mut T` but non-zero and [covariant]."},{"DocComment":""},{"DocComment":" This is often the correct thing to use when building data structures using"},{"DocComment":" raw pointers, but is ultimately more dangerous to use because of its additional"},{"DocComment":" properties. If you're not sure if you should use `NonNull<T>`, just use `*mut T`!"},{"DocComment":""},{"DocComment":" Unlike `*mut T`, the pointer must always be non-null, even if the pointer"},{"DocComment":" is never dereferenced. This is so that enums may use this forbidden value"},{"DocComment":" as a discriminant -- `Option<NonNull<T>>` has the same size as `*mut T`."},{"DocComment":" However the pointer may still dangle if it isn't dereferenced."},{"DocComment":""},{"DocComment":" Unlike `*mut T`, `NonNull<T>` is covariant over `T`. This is usually the correct"},{"DocComment":" choice for most data structures and safe abstractions, such as `Box`, `Rc`, `Arc`, `Vec`,"},{"DocComment":" and `LinkedList`."},{"DocComment":""},{"DocComment":" In rare cases, if your type exposes a way to mutate the value of `T` through a `NonNull<T>`,"},{"DocComment":" and you need to prevent unsoundness from variance (for example, if `T` could be a reference"},{"DocComment":" with a shorter lifetime), you should add a field to make your type invariant, such as"},{"DocComment":" `PhantomData<Cell<T>>` or `PhantomData<&'a mut T>`."},{"DocComment":""},{"DocComment":" Example of a type that must be invariant:"},{"DocComment":" ```rust"},{"DocComment":" use std::cell::Cell;"},{"DocComment":" use std::marker::PhantomData;"},{"DocComment":" struct Invariant<T> {"},{"DocComment":"     ptr: std::ptr::NonNull<T>,"},{"DocComment":"     _invariant: PhantomData<Cell<T>>,"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Notice that `NonNull<T>` has a `From` instance for `&T`. However, this does"},{"DocComment":" not change the fact that mutating through a (pointer derived from a) shared"},{"DocComment":" reference is undefined behavior unless the mutation happens inside an"},{"DocComment":" [`UnsafeCell<T>`]. The same goes for creating a mutable reference from a shared"},{"DocComment":" reference. When using this `From` instance without an `UnsafeCell<T>`,"},{"DocComment":" it is your responsibility to ensure that `as_mut` is never called, and `as_ptr`"},{"DocComment":" is never used for mutation."},{"DocComment":""},{"DocComment":" # Representation"},{"DocComment":""},{"DocComment":" Thanks to the [null pointer optimization],"},{"DocComment":" `NonNull<T>` and `Option<NonNull<T>>`"},{"DocComment":" are guaranteed to have the same size and alignment:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ptr::NonNull;"},{"DocComment":""},{"DocComment":" assert_eq!(size_of::<NonNull<i16>>(), size_of::<Option<NonNull<i16>>>());"},{"DocComment":" assert_eq!(align_of::<NonNull<i16>>(), align_of::<Option<NonNull<i16>>>());"},{"DocComment":""},{"DocComment":" assert_eq!(size_of::<NonNull<str>>(), size_of::<Option<NonNull<str>>>());"},{"DocComment":" assert_eq!(align_of::<NonNull<str>>(), align_of::<Option<NonNull<str>>>());"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [covariant]: https://doc.rust-lang.org/reference/subtyping.html"},{"DocComment":" [`PhantomData`]: crate::marker::PhantomData"},{"DocComment":" [`UnsafeCell<T>`]: crate::cell::UnsafeCell"},{"DocComment":" [null pointer optimization]: crate::option#representation"},{"Unknown":{"path":"rustc_nonnull_optimization_guaranteed","args":null}},{"Unknown":{"path":"rustc_diagnostic_item","args":"NonNull"}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":null},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[{"span":{"data":{"file_id":10,"beg":{"line":76,"col":1},"end":{"line":76,"col":36}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"pointer","ty":{"HashConsedValue":[67,{"RawPtr":[{"Deduplicated":13},"Shared"]}]}}]},"layout":{"size":8,"align":8,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[0],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":24,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["ptr",0]},{"Ident":["NonNull",0]},{"Instantiated":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"regions":[],"types":[{"Deduplicated":11}],"const_generics":[],"trait_refs":[]},"kind":"Other"}}],"span":{"data":{"file_id":10,"beg":{"line":76,"col":1},"end":{"line":76,"col":36}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" `*mut T` but non-zero and [covariant]."},{"DocComment":""},{"DocComment":" This is often the correct thing to use when building data structures using"},{"DocComment":" raw pointers, but is ultimately more dangerous to use because of its additional"},{"DocComment":" properties. If you're not sure if you should use `NonNull<T>`, just use `*mut T`!"},{"DocComment":""},{"DocComment":" Unlike `*mut T`, the pointer must always be non-null, even if the pointer"},{"DocComment":" is never dereferenced. This is so that enums may use this forbidden value"},{"DocComment":" as a discriminant -- `Option<NonNull<T>>` has the same size as `*mut T`."},{"DocComment":" However the pointer may still dangle if it isn't dereferenced."},{"DocComment":""},{"DocComment":" Unlike `*mut T`, `NonNull<T>` is covariant over `T`. This is usually the correct"},{"DocComment":" choice for most data structures and safe abstractions, such as `Box`, `Rc`, `Arc`, `Vec`,"},{"DocComment":" and `LinkedList`."},{"DocComment":""},{"DocComment":" In rare cases, if your type exposes a way to mutate the value of `T` through a `NonNull<T>`,"},{"DocComment":" and you need to prevent unsoundness from variance (for example, if `T` could be a reference"},{"DocComment":" with a shorter lifetime), you should add a field to make your type invariant, such as"},{"DocComment":" `PhantomData<Cell<T>>` or `PhantomData<&'a mut T>`."},{"DocComment":""},{"DocComment":" Example of a type that must be invariant:"},{"DocComment":" ```rust"},{"DocComment":" use std::cell::Cell;"},{"DocComment":" use std::marker::PhantomData;"},{"DocComment":" struct Invariant<T> {"},{"DocComment":"     ptr: std::ptr::NonNull<T>,"},{"DocComment":"     _invariant: PhantomData<Cell<T>>,"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Notice that `NonNull<T>` has a `From` instance for `&T`. However, this does"},{"DocComment":" not change the fact that mutating through a (pointer derived from a) shared"},{"DocComment":" reference is undefined behavior unless the mutation happens inside an"},{"DocComment":" [`UnsafeCell<T>`]. The same goes for creating a mutable reference from a shared"},{"DocComment":" reference. When using this `From` instance without an `UnsafeCell<T>`,"},{"DocComment":" it is your responsibility to ensure that `as_mut` is never called, and `as_ptr`"},{"DocComment":" is never used for mutation."},{"DocComment":""},{"DocComment":" # Representation"},{"DocComment":""},{"DocComment":" Thanks to the [null pointer optimization],"},{"DocComment":" `NonNull<T>` and `Option<NonNull<T>>`"},{"DocComment":" are guaranteed to have the same size and alignment:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ptr::NonNull;"},{"DocComment":""},{"DocComment":" assert_eq!(size_of::<NonNull<i16>>(), size_of::<Option<NonNull<i16>>>());"},{"DocComment":" assert_eq!(align_of::<NonNull<i16>>(), align_of::<Option<NonNull<i16>>>());"},{"DocComment":""},{"DocComment":" assert_eq!(size_of::<NonNull<str>>(), size_of::<Option<NonNull<str>>>());"},{"DocComment":" assert_eq!(align_of::<NonNull<str>>(), align_of::<Option<NonNull<str>>>());"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [covariant]: https://doc.rust-lang.org/reference/subtyping.html"},{"DocComment":" [`PhantomData`]: crate::marker::PhantomData"},{"DocComment":" [`UnsafeCell<T>`]: crate::cell::UnsafeCell"},{"DocComment":" [null pointer optimization]: crate::option#representation"},{"Unknown":{"path":"rustc_nonnull_optimization_guaranteed","args":null}},{"Unknown":{"path":"rustc_diagnostic_item","args":"NonNull"}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":null},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[{"span":{"data":{"file_id":10,"beg":{"line":76,"col":1},"end":{"line":76,"col":36}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"pointer","ty":{"HashConsedValue":[97,{"RawPtr":[{"Deduplicated":11},"Shared"]}]}}]},"layout":{"size":8,"align":8,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[0],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":25,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["sync",0]},{"Ident":["poison",0]},{"Ident":["Guard",0]}],"span":{"data":{"file_id":4,"beg":{"line":158,"col":1},"end":{"line":158,"col":24}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"is_local":false,"opacity":"Transparent","lang_item":null},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[{"span":{"data":{"file_id":4,"beg":{"line":158,"col":1},"end":{"line":158,"col":24}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"panicking","ty":{"HashConsedValue":[27,{"Literal":"Bool"}]}}]},"layout":{"size":1,"align":1,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[0],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":26,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["sync",0]},{"Ident":["PoisonError",0]},{"Instantiated":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"regions":[],"types":[{"Deduplicated":71}],"const_generics":[],"trait_refs":[]},"kind":"Other"}}],"span":{"data":{"file_id":4,"beg":{"line":197,"col":1},"end":{"line":197,"col":26}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" A type of error which can be returned whenever a lock is acquired."},{"DocComment":""},{"DocComment":" Both [`Mutex`]es and [`RwLock`]s are poisoned whenever a thread fails while the lock"},{"DocComment":" is held. The precise semantics for when a lock is poisoned is documented on"},{"DocComment":" each lock. For a lock in the poisoned state, unless the state is cleared manually,"},{"DocComment":" all future acquisitions will return this error."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::sync::{Arc, Mutex};"},{"DocComment":" use std::thread;"},{"DocComment":""},{"DocComment":" let mutex = Arc::new(Mutex::new(1));"},{"DocComment":""},{"DocComment":" // poison the mutex"},{"DocComment":" let c_mutex = Arc::clone(&mutex);"},{"DocComment":" let _ = thread::spawn(move || {"},{"DocComment":"     let mut data = c_mutex.lock().unwrap();"},{"DocComment":"     *data = 2;"},{"DocComment":"     panic!();"},{"DocComment":" }).join();"},{"DocComment":""},{"DocComment":" match mutex.lock() {"},{"DocComment":"     Ok(_) => unreachable!(),"},{"DocComment":"     Err(p_err) => {"},{"DocComment":"         let data = p_err.get_ref();"},{"DocComment":"         println!(\"recovered: {data}\");"},{"DocComment":"     }"},{"DocComment":" };"},{"DocComment":" ```"},{"DocComment":" [`Mutex`]: crate::sync::Mutex"},{"DocComment":" [`RwLock`]: crate::sync::RwLock"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":null},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[{"span":{"data":{"file_id":4,"beg":{"line":197,"col":1},"end":{"line":197,"col":26}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"data","ty":{"Deduplicated":71}}]},"layout":{"size":1,"align":1,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[0],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":27,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["sync",0]},{"Ident":["atomic",0]},{"Ident":["AtomicUsize",0]}],"span":{"data":{"file_id":5,"beg":{"line":3988,"col":1},"end":{"line":3992,"col":2}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" An integer type which can be safely shared between threads."},{"DocComment":""},{"DocComment":" This type has the same"},{"DocComment":"size and bit validity"},{"DocComment":" as the underlying integer type, [`"},{"DocComment":"usize"},{"DocComment":" `]."},{"DocComment":"However, the alignment of this type is always equal to its size, even on targets where [`usize`] has a lesser alignment."},{"DocComment":""},{"DocComment":" For more about the differences between atomic types and"},{"DocComment":" non-atomic types as well as information about the portability of"},{"DocComment":" this type, please see the [module-level documentation]."},{"DocComment":""},{"DocComment":" **Note:** This type is only available on platforms that support"},{"DocComment":" atomic loads and stores of [`"},{"DocComment":"usize"},{"DocComment":" `]."},{"DocComment":""},{"DocComment":" [module-level documentation]: crate::sync::atomic"},{"Unknown":{"path":"rustc_diagnostic_item","args":"AtomicUsize"}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":null},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[{"span":{"data":{"file_id":5,"beg":{"line":3988,"col":1},"end":{"line":3992,"col":2}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"v","ty":{"HashConsedValue":[76,{"Adt":{"id":{"Adt":28},"generics":{"regions":[],"types":[],"const_generics":[],"trait_refs":[]}}}]}}]},"layout":{"size":8,"align":8,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[0],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":28,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["cell",0]},{"Ident":["UnsafeCell",0]},{"Instantiated":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"regions":[],"types":[{"Deduplicated":10}],"const_generics":[],"trait_refs":[]},"kind":"Other"}}],"span":{"data":{"file_id":6,"beg":{"line":2300,"col":1},"end":{"line":2300,"col":33}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" The core primitive for interior mutability in Rust."},{"DocComment":""},{"DocComment":" If you have a reference `&T`, then normally in Rust the compiler performs optimizations based on"},{"DocComment":" the knowledge that `&T` points to immutable data. Mutating that data, for example through an"},{"DocComment":" alias or by transmuting a `&T` into a `&mut T`, is considered undefined behavior."},{"DocComment":" `UnsafeCell<T>` opts-out of the immutability guarantee for `&T`: a shared reference"},{"DocComment":" `&UnsafeCell<T>` may point to data that is being mutated. This is called \"interior mutability\"."},{"DocComment":""},{"DocComment":" All other types that allow internal mutability, such as [`Cell<T>`] and [`RefCell<T>`], internally"},{"DocComment":" use `UnsafeCell` to wrap their data."},{"DocComment":""},{"DocComment":" Note that only the immutability guarantee for shared references is affected by `UnsafeCell`. The"},{"DocComment":" uniqueness guarantee for mutable references is unaffected. There is *no* legal way to obtain"},{"DocComment":" aliasing `&mut`, not even with `UnsafeCell<T>`."},{"DocComment":""},{"DocComment":" `UnsafeCell` does nothing to avoid data races; they are still undefined behavior. If multiple"},{"DocComment":" threads have access to the same `UnsafeCell`, they must follow the usual rules of the"},{"DocComment":" [concurrent memory model]: conflicting non-synchronized accesses must be done via the APIs in"},{"DocComment":" [`core::sync::atomic`]."},{"DocComment":""},{"DocComment":" The `UnsafeCell` API itself is technically very simple: [`.get()`] gives you a raw pointer"},{"DocComment":" `*mut T` to its contents. It is up to _you_ as the abstraction designer to use that raw pointer"},{"DocComment":" correctly."},{"DocComment":""},{"DocComment":" [`.get()`]: `UnsafeCell::get`"},{"DocComment":" [concurrent memory model]: ../sync/atomic/index.html#memory-model-for-atomic-accesses"},{"DocComment":""},{"DocComment":" # Aliasing rules"},{"DocComment":""},{"DocComment":" The precise Rust aliasing rules are somewhat in flux, but the main points are not contentious:"},{"DocComment":""},{"DocComment":" - If you create a safe reference with lifetime `'a` (either a `&T` or `&mut T` reference), then"},{"DocComment":"   you must not access the data in any way that contradicts that reference for the remainder of"},{"DocComment":"   `'a`. For example, this means that if you take the `*mut T` from an `UnsafeCell<T>` and cast it"},{"DocComment":"   to an `&T`, then the data in `T` must remain immutable (modulo any `UnsafeCell` data found"},{"DocComment":"   within `T`, of course) until that reference's lifetime expires. Similarly, if you create a"},{"DocComment":"   `&mut T` reference that is released to safe code, then you must not access the data within the"},{"DocComment":"   `UnsafeCell` until that reference expires."},{"DocComment":""},{"DocComment":" - For both `&T` without `UnsafeCell<_>` and `&mut T`, you must also not deallocate the data"},{"DocComment":"   until the reference expires. As a special exception, given an `&T`, any part of it that is"},{"DocComment":"   inside an `UnsafeCell<_>` may be deallocated during the lifetime of the reference, after the"},{"DocComment":"   last time the reference is used (dereferenced or reborrowed). Since you cannot deallocate a part"},{"DocComment":"   of what a reference points to, this means the memory an `&T` points to can be deallocated only if"},{"DocComment":"   *every part of it* (including padding) is inside an `UnsafeCell`."},{"DocComment":""},{"DocComment":" However, whenever a `&UnsafeCell<T>` is constructed or dereferenced, it must still point to"},{"DocComment":" live memory and the compiler is allowed to insert spurious reads if it can prove that this"},{"DocComment":" memory has not yet been deallocated."},{"DocComment":""},{"DocComment":" To assist with proper design, the following scenarios are explicitly declared legal"},{"DocComment":" for single-threaded code:"},{"DocComment":""},{"DocComment":" 1. A `&T` reference can be released to safe code and there it can co-exist with other `&T`"},{"DocComment":"    references, but not with a `&mut T`"},{"DocComment":""},{"DocComment":" 2. A `&mut T` reference may be released to safe code provided neither other `&mut T` nor `&T`"},{"DocComment":"    co-exist with it. A `&mut T` must always be unique."},{"DocComment":""},{"DocComment":" Note that whilst mutating the contents of an `&UnsafeCell<T>` (even while other"},{"DocComment":" `&UnsafeCell<T>` references alias the cell) is"},{"DocComment":" ok (provided you enforce the above invariants some other way), it is still undefined behavior"},{"DocComment":" to have multiple `&mut UnsafeCell<T>` aliases. That is, `UnsafeCell` is a wrapper"},{"DocComment":" designed to have a special interaction with _shared_ accesses (_i.e._, through an"},{"DocComment":" `&UnsafeCell<_>` reference); there is no magic whatsoever when dealing with _exclusive_"},{"DocComment":" accesses (_e.g._, through a `&mut UnsafeCell<_>`): neither the cell nor the wrapped value"},{"DocComment":" may be aliased for the duration of that `&mut` borrow."},{"DocComment":" This is showcased by the [`.get_mut()`] accessor, which is a _safe_ getter that yields"},{"DocComment":" a `&mut T`."},{"DocComment":""},{"DocComment":" [`.get_mut()`]: `UnsafeCell::get_mut`"},{"DocComment":""},{"DocComment":" # Memory layout"},{"DocComment":""},{"DocComment":" `UnsafeCell<T>` has the same in-memory representation as its inner type `T`. A consequence"},{"DocComment":" of this guarantee is that it is possible to convert between `T` and `UnsafeCell<T>`."},{"DocComment":" Special care has to be taken when converting a nested `T` inside of an `Outer<T>` type"},{"DocComment":" to an `Outer<UnsafeCell<T>>` type: this is not sound when the `Outer<T>` type enables [niche]"},{"DocComment":" optimizations. For example, the type `Option<NonNull<u8>>` is typically 8 bytes large on"},{"DocComment":" 64-bit platforms, but the type `Option<UnsafeCell<NonNull<u8>>>` takes up 16 bytes of space."},{"DocComment":" Therefore this is not a valid conversion, despite `NonNull<u8>` and `UnsafeCell<NonNull<u8>>>`"},{"DocComment":" having the same memory layout. This is because `UnsafeCell` disables niche optimizations in"},{"DocComment":" order to avoid its interior mutability property from spreading from `T` into the `Outer` type,"},{"DocComment":" thus this can cause distortions in the type size in these cases."},{"DocComment":""},{"DocComment":" Note that the only valid way to obtain a `*mut T` pointer to the contents of a"},{"DocComment":" _shared_ `UnsafeCell<T>` is through [`.get()`]  or [`.raw_get()`]. A `&mut T` reference"},{"DocComment":" can be obtained by either dereferencing this pointer or by calling [`.get_mut()`]"},{"DocComment":" on an _exclusive_ `UnsafeCell<T>`. Even though `T` and `UnsafeCell<T>` have the"},{"DocComment":" same memory layout, the following is not allowed and undefined behavior:"},{"DocComment":""},{"DocComment":" ```rust,compile_fail"},{"DocComment":" # use std::cell::UnsafeCell;"},{"DocComment":" unsafe fn not_allowed<T>(ptr: &UnsafeCell<T>) -> &mut T {"},{"DocComment":"   let t = ptr as *const UnsafeCell<T> as *mut T;"},{"DocComment":"   // This is undefined behavior, because the `*mut T` pointer"},{"DocComment":"   // was not obtained through `.get()` nor `.raw_get()`:"},{"DocComment":"   unsafe { &mut *t }"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Instead, do this:"},{"DocComment":""},{"DocComment":" ```rust"},{"DocComment":" # use std::cell::UnsafeCell;"},{"DocComment":" // Safety: the caller must ensure that there are no references that"},{"DocComment":" // point to the *contents* of the `UnsafeCell`."},{"DocComment":" unsafe fn get_mut<T>(ptr: &UnsafeCell<T>) -> &mut T {"},{"DocComment":"   unsafe { &mut *ptr.get() }"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Converting in the other direction from a `&mut T`"},{"DocComment":" to an `&UnsafeCell<T>` is allowed:"},{"DocComment":""},{"DocComment":" ```rust"},{"DocComment":" # use std::cell::UnsafeCell;"},{"DocComment":" fn get_shared<T>(ptr: &mut T) -> &UnsafeCell<T> {"},{"DocComment":"   let t = ptr as *mut T as *const UnsafeCell<T>;"},{"DocComment":"   // SAFETY: `T` and `UnsafeCell<T>` have the same memory layout"},{"DocComment":"   unsafe { &*t }"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [niche]: https://rust-lang.github.io/unsafe-code-guidelines/glossary.html#niche"},{"DocComment":" [`.raw_get()`]: `UnsafeCell::raw_get`"},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" Here is an example showcasing how to soundly mutate the contents of an `UnsafeCell<_>` despite"},{"DocComment":" there being multiple references aliasing the cell:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::cell::UnsafeCell;"},{"DocComment":""},{"DocComment":" let x: UnsafeCell<i32> = 42.into();"},{"DocComment":" // Get multiple / concurrent / shared references to the same `x`."},{"DocComment":" let (p1, p2): (&UnsafeCell<i32>, &UnsafeCell<i32>) = (&x, &x);"},{"DocComment":""},{"DocComment":" unsafe {"},{"DocComment":"     // SAFETY: within this scope there are no other references to `x`'s contents,"},{"DocComment":"     // so ours is effectively unique."},{"DocComment":"     let p1_exclusive: &mut i32 = &mut *p1.get(); // -- borrow --+"},{"DocComment":"     *p1_exclusive += 27; //                                     |"},{"DocComment":" } // <---------- cannot go beyond this point -------------------+"},{"DocComment":""},{"DocComment":" unsafe {"},{"DocComment":"     // SAFETY: within this scope nobody expects to have exclusive access to `x`'s contents,"},{"DocComment":"     // so we can have multiple shared accesses concurrently."},{"DocComment":"     let p2_shared: &i32 = &*p2.get();"},{"DocComment":"     assert_eq!(*p2_shared, 42 + 27);"},{"DocComment":"     let p1_shared: &i32 = &*p1.get();"},{"DocComment":"     assert_eq!(*p1_shared, *p2_shared);"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" The following example showcases the fact that exclusive access to an `UnsafeCell<T>`"},{"DocComment":" implies exclusive access to its `T`:"},{"DocComment":""},{"DocComment":" ```rust"},{"DocComment":" #![forbid(unsafe_code)]"},{"DocComment":" // with exclusive accesses, `UnsafeCell` is a transparent no-op wrapper, so no need for"},{"DocComment":" // `unsafe` here."},{"DocComment":" use std::cell::UnsafeCell;"},{"DocComment":""},{"DocComment":" let mut x: UnsafeCell<i32> = 42.into();"},{"DocComment":""},{"DocComment":" // Get a compile-time-checked unique reference to `x`."},{"DocComment":" let p_unique: &mut UnsafeCell<i32> = &mut x;"},{"DocComment":" // With an exclusive reference, we can mutate the contents for free."},{"DocComment":" *p_unique.get_mut() = 0;"},{"DocComment":" // Or, equivalently:"},{"DocComment":" x = UnsafeCell::new(0);"},{"DocComment":""},{"DocComment":" // When we own the value, we can extract the contents for free."},{"DocComment":" let contents: i32 = x.into_inner();"},{"DocComment":" assert_eq!(contents, 0);"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":"unsafe_cell"},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[{"span":{"data":{"file_id":6,"beg":{"line":2300,"col":1},"end":{"line":2300,"col":33}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"value","ty":{"Deduplicated":10}}]},"layout":{"size":8,"align":8,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[0],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":29,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["fmt",0]},{"Ident":["Formatter",0]},{"Instantiated":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"regions":["Erased"],"types":[],"const_generics":[],"trait_refs":[]},"kind":"Other"}}],"span":{"data":{"file_id":11,"beg":{"line":561,"col":1},"end":{"line":561,"col":25}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Configuration for formatting."},{"DocComment":""},{"DocComment":" A `Formatter` represents various options related to formatting. Users do not"},{"DocComment":" construct `Formatter`s directly; a mutable reference to one is passed to"},{"DocComment":" the `fmt` method of all formatting traits, like [`Debug`] and [`Display`]."},{"DocComment":""},{"DocComment":" To interact with a `Formatter`, you'll call various methods to change the"},{"DocComment":" various options related to formatting. For examples, please see the"},{"DocComment":" documentation of the methods defined on `Formatter` below."},{"Unknown":{"path":"rustc_diagnostic_item","args":"Formatter"}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":null},"generics":