,{"DocComment":" dropped (falls out of scope), the lock will be unlocked."},{"DocComment":""},{"DocComment":" The data protected by the mutex can be accessed through this guard via its"},{"DocComment":" [`Deref`] and [`DerefMut`] implementations."},{"DocComment":""},{"DocComment":" This structure is created by the [`lock`] and [`try_lock`] methods on"},{"DocComment":" [`Mutex`]."},{"DocComment":""},{"DocComment":" [`lock`]: Mutex::lock"},{"DocComment":" [`try_lock`]: Mutex::try_lock"},{"Unknown":{"path":"clippy::has_significant_drop","args":null}},{"Unknown":{"path":"rustc_diagnostic_item","args":"MutexGuard"}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Transparent","lang_item":null},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":{"Struct":[{"span":{"data":{"file_id":2,"beg":{"line":277,"col":1},"end":{"line":277,"col":42}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"lock","ty":{"Deduplicated":4}},{"span":{"data":{"file_id":2,"beg":{"line":277,"col":1},"end":{"line":277,"col":42}},"generated_from_span":null},"attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"name":"poison","ty":{"Deduplicated":71}}]},"layout":{"size":16,"align":8,"discriminant_layout":null,"uninhabited":false,"variant_layouts":[{"field_offsets":[0,8],"uninhabited":false,"tag":null}]},"ptr_metadata":"None","repr":null},{"def_id":2,"item_meta":{"name":[{"Ident":["std",0]},{"Ident":["result",0]},{"Ident":["Result",0]},{"Instantiated":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"regions":[],"types":[{"Deduplicated":2},{"Deduplicated":39}],"const_generics":[],"trait_refs":[]},"kind":"Other"}}],"span":{"data":{"file_id":7,"beg":{"line":557,"col":1},"end":{"lin